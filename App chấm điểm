<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI English Pronunciation Checker</title>
    <style>
        :root {
            --primary: #4A90E2;
            --success: #2ECC71;
            --danger: #E74C3C;
            --dark: #2C3E50;
            --light: #F8F9FA;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #e0eafc, #cfdef3);
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            background: white;
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            max-width: 500px;
            width: 100%;
            text-align: center;
        }

        h1 {
            color: var(--dark);
            margin-bottom: 5px;
            font-size: 24px;
        }

        p.subtitle {
            color: #7f8c8d;
            margin-bottom: 25px;
            font-size: 14px;
        }

        .word-box {
            background: var(--light);
            padding: 20px;
            border-radius: 12px;
            border: 2px dashed #bdc3c7;
            margin-bottom: 20px;
        }

        .target-text {
            font-size: 28px;
            font-weight: bold;
            color: var(--primary);
            margin: 0 0 10px 0;
        }

        .btn-next {
            background: none;
            border: 1px solid var(--primary);
            color: var(--primary);
            padding: 5px 15px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.3s;
        }

        .btn-next:hover {
            background: var(--primary);
            color: white;
        }

        .btn-mic {
            background-color: var(--primary);
            color: white;
            border: none;
            width: 70px;
            height: 70px;
            border-radius: 50%;
            font-size: 24px;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(74, 144, 226, 0.4);
            transition: all 0.3s ease;
            display: inline-flex;
            justify-content: center;
            align-items: center;
            outline: none;
        }

        .btn-mic:hover {
            transform: scale(1.05);
        }

        .btn-mic.recording {
            background-color: var(--danger);
            animation: pulse 1.5s infinite;
            box-shadow: 0 5px 15px rgba(231, 76, 60, 0.4);
        }

        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }

        .status {
            margin-top: 15px;
            font-weight: 500;
            color: #7f8c8d;
            min-height: 22px;
        }

        .result-section {
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid #eee;
            display: none;
        }

        .score {
            font-size: 48px;
            font-weight: 800;
            margin-bottom: 10px;
        }

        .score.perfect { color: var(--success); }
        .score.good { color: #F39C12; }
        .score.bad { color: var(--danger); }

        .transcript {
            font-size: 16px;
            color: var(--dark);
            background: #fcfcfc;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #eee;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>Luyện Phát Âm Tiếng Anh</h1>
    <p class="subtitle">Chuẩn giọng Anh - Mỹ (en-US) bằng Google AI</p>

    <div class="word-box">
        <p class="target-text" id="targetWord">Beautiful</p>
        <button class="btn-next" onclick="nextWord()">Đổi từ khác ↻</button>
    </div>

    <button class="btn-mic" id="micBtn" onclick="toggleListening()">🎤</button>
    <div class="status" id="statusText">Bấm mic và đọc từ phía trên</div>

    <div class="result-section" id="resultSection">
        <div class="score" id="scoreValue">0%</div>
        <p style="margin:0 0 5px 0; font-size: 12px; color: #95a5a6;">Bạn đã đọc thành:</p>
        <div class="transcript" id="userTranscript">...</div>
    </div>
</div>

<script>
    // Danh sách từ vựng mẫu để luyện tập
    const wordList = [
        "Beautiful", "Literature", "Schedule", "Comfortable", "Water", 
        "Mountain", "University", "International", "Chocolate", "Library"
    ];

    let currentTarget = "Beautiful";
    let isListening = false;
    
    // Khởi tạo Speech Recognition (Google API tích hợp sẵn trong trình duyệt)
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    let recognition;

    if (SpeechRecognition) {
        recognition = new SpeechRecognition();
        recognition.continuous = false; // Ngắt khi người dùng dừng nói
        recognition.lang = 'en-US';     // Thiết lập chuẩn giọng Anh - Mỹ
        recognition.interimResults = false; // Chỉ lấy kết quả cuối cùng

        // Xử lý khi bắt đầu nhận diện
        recognition.onstart = () => {
            isListening = true;
            document.getElementById('micBtn').classList.add('recording');
            document.getElementById('statusText').innerText = "Đang lắng nghe... Hãy nói đi!";
            document.getElementById('statusText').style.color = "#E74C3C";
        };

        // Xử lý khi có kết quả trả về từ Google AI
        recognition.onresult = (event) => {
            const resultText = event.results[0][0].transcript;
            analyzePronunciation(resultText);
        };

        // Xử lý khi kết thúc hoặc lỗi
        recognition.onend = () => {
            isListening = false;
            document.getElementById('micBtn').classList.remove('recording');
        };

        recognition.onerror = (event) => {
            document.getElementById('statusText').innerText = "Không nghe rõ, vui lòng thử lại.";
            document.getElementById('statusText').style.color = "#7f8c8d";
        };
    } else {
        alert("Trình duyệt của bạn không hỗ trợ nhận diện giọng nói. Hãy dùng Google Chrome!");
    }

    // Hàm Bật/Tắt Mic
    function toggleListening() {
        if (!recognition) return;
        if (isListening) {
            recognition.stop();
        } else {
            document.getElementById('resultSection').style.display = "none";
            recognition.start();
        }
    }

    // Hàm chuyển sang từ ngẫu nhiên khác
    function nextWord() {
        const randomIndex = Math.floor(Math.random() * wordList.length);
        currentTarget = wordList[randomIndex];
        document.getElementById('targetWord').innerText = currentTarget;
        document.getElementById('resultSection').style.display = "none";
        document.getElementById('statusText').innerText = "Bấm mic và đọc từ phía trên";
        document.getElementById('statusText').style.color = "#7f8c8d";
    }

    // Thuật toán so sánh chuỗi Levenshtein để chấm điểm % chính xác
    function getSimilarity(s1, s2) {
        let longer = s1;
        let shorter = s2;
        if (s1.length < s2.length) {
            longer = s2;
            shorter = s1;
        }
        let longerLength = longer.length;
        if (longerLength === 0) {
            return 100;
        }
        return Math.round((longerLength - editDistance(longer, shorter)) / longerLength * 100);
    }

    function editDistance(s1, s2) {
        s1 = s1.toLowerCase();
        s2 = s2.toLowerCase();
        let costs = new Array();
        for (let i = 0; i <= s1.length; i++) {
            let lastValue = i;
            for (let j = 0; j <= s2.length; j++) {
                if (i == 0)
                    costs[j] = j;
                else {
                    if (j > 0) {
                        let newValue = costs[j - 1];
                        if (s1.charAt(i - 1) != s2.charAt(j - 1))
                            newValue = Math.min(Math.min(newValue, lastValue), costs[j]) + 1;
                        costs[j - 1] = lastValue;
                        lastValue = newValue;
                    }
                }
            }
            if (i > 0)
                costs[s2.length] = lastValue;
        }
        return costs[s2.length];
    }

    // Hàm phân tích và hiển thị kết quả chấm điểm
    function analyzePronunciation(spokenText) {
        // Làm sạch chuỗi (xóa dấu chấm, phẩy, khoảng trắng thừa)
        const cleanTarget = currentTarget.trim().toLowerCase().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()]/g,"");
        const cleanSpoken = spokenText.trim().toLowerCase().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()]/g,"");

        // Tính điểm phần trăm giống nhau giữa từ mẫu và từ người dùng đọc
        let score = getSimilarity(cleanTarget, cleanSpoken);

        // Hiển thị kết quả lên giao diện
        document.getElementById('userTranscript').innerText = spokenText;
        
        const scoreEl = document.getElementById('scoreValue');
        scoreEl.innerText = score + "%";
        
        // Đổi màu sắc theo thang điểm
        scoreEl.className = "score"; // reset
        if (score >= 80) {
            scoreEl.classList.add('perfect');
            document.getElementById('statusText').innerText = "Tuyệt vời! Phát âm rất chuẩn.";
            document.getElementById('statusText').style.color = "#2ECC71";
        } else if (score >= 50) {
            scoreEl.classList.add('good');
            document.getElementById('statusText').innerText = "Tạm ổn, cần cải thiện một chút.";
            document.getElementById('statusText').style.color = "#F39C12";
        } else {
            scoreEl.classList.add('bad');
            document.getElementById('statusText').innerText = "Chưa chính xác, thử lại nhé!";
            document.getElementById('statusText').style.color = "#E74C3C";
        }

        document.getElementById('resultSection').style.display = "block";
    }
</script>

</body>
</html>
